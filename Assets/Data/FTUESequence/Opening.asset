%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 8667f7ca8a0a87041be78d2dfba64aa8, type: 3}
  m_Name: Opening
  m_EditorClassIdentifier: Assembly-CSharp::FTUESequence
  steps:
  - TargetID: ItemView
    RequiredEvent: 
    Message: <color=green><b>Collectable:</b></color> Match and collect these special
      items to win the level!
    RequireClick: 0
    ShowCutout: 1
    ShowHand: 1
    CustomSize: 0.07
    HandDirection: 2
  - TargetID: Item1
    RequiredEvent: 
    Message: Tap the <color=red><b>first</b></color> item!
    RequireClick: 1
    ShowCutout: 1
    ShowHand: 1
    CustomSize: 0.1
    HandDirection: 1
  - TargetID: Item2
    RequiredEvent: 
    Message: Tap the <color=red><b>second</b></color>. We are almost there!!
    RequireClick: 1
    ShowCutout: 1
    ShowHand: 1
    CustomSize: 0.1
    HandDirection: 3
  - TargetID: Item3
    RequiredEvent: 
    Message: Finally, tap the <color=red><b>third</b></color>  item to clear the
      item and score!!
    RequireClick: 1
    ShowCutout: 1
    ShowHand: 1
    CustomSize: 0.1
    HandDirection: 4
  - TargetID: 
    RequiredEvent: 
    Message: <color=green><b>Woohoo!!</b></color> Now collect the rest of the items
      to win the level!
    RequireClick: 0
    ShowCutout: 0
    ShowHand: 0
    CustomSize: 0
    HandDirection: 2
